# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Unified research tools (same registry, different backends)
# MCP backend for market data/news
MCP_SERVERS=[{"server_id":"yfinance","transport":"stdio","command":"uvx","args":["yfmcp@latest"]}]

# Optional web backends in the same tool system
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
AGENT_BROWSER_ENDPOINT=

# Runtime
DEFAULT_USER_ID=demo_user
TRACE_OUTPUT_DIR=./trace_logs
REPORT_OUTPUT_DIR=./reports
