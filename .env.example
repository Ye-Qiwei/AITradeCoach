# ==============================================================================
# LLM Configuration
# ==============================================================================
# Specify the LLM provider and the corresponding API key.
# Supported providers: "openai", "gemini"
LLM_PROVIDER=openai
OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional: Specify a model name.
# Defaults: "gpt-4o-mini" (openai), "gemini-2.5-pro" (gemini)
LLM_MODEL=gpt-5-mini-2025-08-07


# ==============================================================================
# Tools & Services Configuration
# ==============================================================================
# At least one tool must be available for the system to run.

# ------------------------------------------------------------------------------
# Category 1: API Key-based Services (External HTTP)
# ------------------------------------------------------------------------------

# Brave Search — web discovery tool (https://brave.com/search/api/)
BRAVE_API_KEY=

# Firecrawl — article body extraction (https://firecrawl.dev/)
FIRECRAWL_API_KEY=

# Playwright — JS-rendered page fetching.
# Requires a running browser automation server, e.g. https://github.com/browserless/chrome
AGENT_BROWSER_ENDPOINT=


# ------------------------------------------------------------------------------
# Category 2: MCP (Model Context Protocol) Services
# ------------------------------------------------------------------------------
# MCP is an open standard by Anthropic for connecting AI models to external tools.
# The value is a JSON array defining how to start and connect to MCP services.
#
# The default config launches a local yfinance MCP server via uvx (requires uv installed).
# See: https://github.com/narumiruna/yfinance-mcp
MCP_SERVERS=[{"server_id":"yfinance","transport":"stdio","command":"uvx","args":["yfmcp@latest"]}]


# ==============================================================================
# Output & Storage Configuration
# ==============================================================================
# User ID used when --user-id is not specified in the CLI. Affects file naming.
DEFAULT_USER_ID=demo_user

# Directory where final Markdown reports are saved.
TRACE_OUTPUT_DIR=./trace_logs

# Directory where run trace JSON files are saved.
REPORT_OUTPUT_DIR=./reports


# ==============================================================================
# Optional: Runtime & Agent Tuning
# ==============================================================================
# Maximum tool-call rounds per Judgement in the ReAct agent.
# REACT_MAX_ITERATIONS=6

# Maximum number of tool call failures tolerated before giving up.
# REACT_MAX_TOOL_FAILURES=2

# Minimum number of distinct sources required for evidence to be considered sufficient.
# REACT_REQUIRE_MIN_SOURCES=2

# Maximum number of report rewrite attempts after a failed judge review.
# AGENT_MAX_REWRITE_ROUNDS=2

# MCP tool call timeout in seconds.
# MCP_TIMEOUT_SECONDS=60

# Number of retries for failed MCP tool calls.
# MCP_MAX_RETRIES=1
