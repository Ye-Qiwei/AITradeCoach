# Runtime profile: local | test | prod
ENV=local
DEBUG=true

# LLM
# Select provider: openai | gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
# Keep both keys available and switch by LLM_PROVIDER
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro

# MCP servers (JSON array): stdio/http/sse
MCP_SERVERS=[{"server_id":"yahoo_finance","transport":"stdio","command":"python","args":["-m","your_mcp_yahoo_server"]},{"server_id":"sec_edgar","transport":"stdio","command":"python","args":["-m","your_mcp_sec_server"]},{"server_id":"fred","transport":"stdio","command":"python","args":["-m","your_mcp_fred_server"]},{"server_id":"rss_search","transport":"stdio","command":"python","args":["-m","ai_trading_coach.modules.mcp.rss_server_example"]}]
MCP_TOOL_ALLOWLIST=yahoo_finance:price_history,sec_edgar:list_filings,fred:series_observations,rss_search:rss_search
EVIDENCE_TOOL_MAP={"price_path":"yahoo_finance:price_history","news":"rss_search:rss_search","filing":"sec_edgar:list_filings","macro":"fred:series_observations"}
MCP_TIMEOUT_SECONDS=20
MCP_MAX_RETRIES=1

# Agent controls
AGENT_MAX_REWRITE_ROUNDS=2
CONTEXT_BUDGET_PLANNER=6000
CONTEXT_BUDGET_REPORTER=9000
CONTEXT_BUDGET_JUDGE=5000

# Paths / misc
TRACE_OUTPUT_DIR=./trace_logs
REPORT_OUTPUT_DIR=./reports
LOG_LEVEL=INFO
PROMPT_VERSION=agent_v2
PROMPT_REGISTRY_PATH=./config/prompts
CHROMA_PERSIST_DIR=./.chroma
