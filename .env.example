# Runtime profile: local | test | prod
ATC_ENV=local
ATC_DEBUG=true

# Core model provider
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
ATC_USE_GEMINI=false
ATC_MODEL_TIMEOUT_SECONDS=20
ATC_ENABLE_LLM_COGNITION=false
ATC_ENABLE_LLM_REPORT=false
ATC_LLM_PROVIDER=gemini
ATC_LLM_MODEL=
ATC_LLM_TIMEOUT_SECONDS=20
MODEL_DEFAULT=
MODEL_LOG_UNDERSTANDING=
MODEL_COGNITION_EXTRACTION=
MODEL_EVIDENCE_PLANNING=
MODEL_WINDOW_SELECTION=
MODEL_COGNITION_EVALUATION=
MODEL_REPORT_GENERATION=
MODEL_PROMPTOPS=
# Tip: leave module model variables empty to use MODEL_DEFAULT (or GEMINI_MODEL fallback)

# Memory storage
CHROMA_PERSIST_DIR=./.chroma
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# MCP gateway
MCP_TIMEOUT_SECONDS=12
MCP_MAX_RETRIES=2
MCP_SERVERS=search,price,filing,news,sentiment,discussion,macro

# Scheduling
SCHEDULER_CRON=0 20 * * 1-5
DEFAULT_USER_ID=demo_user

# Observability
TRACE_OUTPUT_DIR=./trace_logs
REPORT_OUTPUT_DIR=./reports
LOG_LEVEL=INFO

# PromptOps
PROMPT_VERSION=baseline_v1
PROMPT_REGISTRY_PATH=./config/prompts
