# Runtime profile: local | test | prod
ENV=local
DEBUG=true

# LLM
# Select provider: openai | gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
# Keep both keys available and switch by LLM_PROVIDER
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-pro

# General web research tools (optional but recommended)
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
# Optional HTTP browser bridge. If empty, playwright_fetch will try local Playwright runtime.
AGENT_BROWSER_ENDPOINT=

# MCP servers (optional). Leave empty to disable MCP tools and rely on web tools.
MCP_SERVERS=[]
MCP_TOOL_ALLOWLIST=
EVIDENCE_TOOL_MAP=
# Full MCP example with yfinance:
# MCP_SERVERS=[{"server_id":"yfinance","transport":"stdio","command":"uv","args":["--directory","/ABS/PATH/yahoo-finance-mcp","run","server.py"]},{"server_id":"rss_search","transport":"stdio","command":"python3","args":["-m","ai_trading_coach.modules.mcp.rss_server_example"]}]
# MCP_TOOL_ALLOWLIST=yfinance:yfinance_get_price_history,yfinance:yfinance_get_ticker_news,rss_search:rss_search
# EVIDENCE_TOOL_MAP={"price_path":"yfinance:yfinance_get_price_history","news":"yfinance:yfinance_get_ticker_news"}
# Optional stock-news mapping:
# EVIDENCE_TOOL_MAP={"price_path":"yfinance:yfinance_get_price_history","news":"rss_search:rss_search"}
MCP_TIMEOUT_SECONDS=20
MCP_MAX_RETRIES=1

# Agent controls
AGENT_MAX_REWRITE_ROUNDS=2
CONTEXT_BUDGET_PLANNER=6000
CONTEXT_BUDGET_REPORTER=9000
CONTEXT_BUDGET_JUDGE=5000

# Paths / misc
TRACE_OUTPUT_DIR=./trace_logs
REPORT_OUTPUT_DIR=./reports
LOG_LEVEL=INFO
PROMPT_VERSION=agent_v2
PROMPT_REGISTRY_PATH=./config/prompts
CHROMA_PERSIST_DIR=./.chroma
